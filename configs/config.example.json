{
  "api_key": "${OGC_API_KEY}",
  "host": "127.0.0.1",
  "port": 3456,

  "models": {
    "gpt-4o": {
      "provider": "openai",
      "model_id": "gpt-4o",
      "temperature": 0.7,
      "max_tokens": 4096
    },
    "claude-opus-4": {
      "provider": "anthropic",
      "model_id": "claude-opus-4-20250514",
